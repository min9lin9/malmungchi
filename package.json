{
  "name": "malmungchi",
  "version": "1.0.0",
  "description": "Local document memory, source lifecycle, search, and persona workflows for Codex",
  "type": "module",
  "main": "src/main.ts",
  "bin": {
    "malmungchi": "bin/malmungchi"
  },
  "files": [
    "bin",
    "src",
    "skill-kit/src",
    "skill-kit/skills",
    "fixtures",
    "requirements-eval4sim.txt"
  ],
  "exports": {
    ".": "./src/main.ts",
    "./bootstrap": "./src/bootstrap.ts",
    "./config/env": "./src/config/env.ts",
    "./http/app": "./src/http/app.ts",
    "./mcp/server": "./src/mcp/server.ts",
    "./search/engine-factory": "./src/search/engine-factory.ts",
    "./search/flexsearch-engine": "./src/search/flexsearch-engine.ts",
    "./search/meilisearch-engine": "./src/search/meilisearch-engine.ts",
    "./search/search-engine": "./src/search/search-engine.ts",
    "./service/document-service": "./src/service/document-service.ts",
    "./service/document-store": "./src/service/document-store.ts",
    "./ingest/load-documents": "./src/ingest/load-documents.ts",
    "./ingest/build-manifest": "./src/ingest/build-manifest.ts",
    "./ingest/diff-documents": "./src/ingest/diff-documents.ts",
    "./ingest/incremental-update": "./src/ingest/incremental-update.ts",
    "./domain/document": "./src/domain/document.ts",
    "./domain/errors": "./src/domain/errors.ts",
    "./util/logger": "./src/util/logger.ts"
  },
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "start:stdio": "MALMUNGCHI_TRANSPORT=stdio bun src/main.ts",
    "start:http": "MALMUNGCHI_TRANSPORT=http bun src/main.ts",
    "malmungchi": "bun skill-kit/src/index.ts",
    "build:manifest": "bun src/cli/build-manifest.ts",
    "update:malmungchi": "bun src/cli/update-documents.ts",
    "sync:meilisearch": "bun src/cli/sync-meilisearch.ts",
    "compare:engines": "bun src/cli/compare-engines.ts",
    "validate:data": "bun src/cli/validate-data.ts",
    "inspect:index": "bun src/cli/inspect-index.ts",
    "benchmark": "bun src/cli/benchmark.ts",
    "smoke:prototype": "bun scripts/prototype-smoke.ts",
    "login:openai": "codex login",
    "ci": "bun run typecheck && bun run lint && bun run validate:data && bun run test:search-quality && bun run test:coverage && bun run smoke:prototype && bun run security:check",
    "ci:local": "bun run typecheck && bun run lint && bun test tests/source-lifecycle.test.ts tests/source-lifecycle-hardening.test.ts tests/prototype-export-checksums.test.ts skill-kit/tests/persona-generator.test.ts skill-kit/tests/persona-parity.test.ts --timeout 10000",
    "qa:e2e": "bun skill-kit/src/index.ts qa:e2e",
    "qa:assert-clean": "bun skill-kit/src/index.ts qa:assert-clean",
    "validate:skills": "for skill in skill-kit/skills/malmungchi skill-kit/skills/ingestion skill-kit/skills/author-source-generator skill-kit/skills/persona-generator skill-kit/skills/panel-debate; do python3 /home/burt/.codex/skills/.system/skill-creator/scripts/quick_validate.py \"$skill\"; done",
    "security:check": "bun skill-kit/src/index.ts security:check",
    "benchmark:persona": "bun skill-kit/src/index.ts benchmark:persona",
    "eval4sim:install": "python3 -m venv .venv && .venv/bin/python -m pip install -r requirements-eval4sim.txt",
    "eval4sim:doctor": "bun skill-kit/src/index.ts eval4sim:doctor",
    "eval4sim:smoke-real": "bun skill-kit/src/index.ts eval4sim:smoke-real",
    "audit:plan-compliance": "bun skill-kit/src/index.ts audit:plan-compliance",
    "test": "bun test",
    "test:search-quality": "bun test tests/search/flexsearch-rerank.test.ts tests/search/rrf-ranking.test.ts tests/search/embedding-reranker.test.ts",
    "test:coverage": "bun scripts/check-coverage.ts",
    "typecheck": "tsc --noEmit",
    "release:check": "bun run ci && bun run benchmark",
    "release": "bun scripts/release.ts",
    "lint": "biome check src tests skill-kit/src skill-kit/tests skill-kit/skills",
    "lint:fix": "biome check --write src tests skill-kit/src skill-kit/tests skill-kit/skills",
    "format": "biome format --write src tests skill-kit/src skill-kit/tests skill-kit/skills"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "elysia": "^1.2.0",
    "flexsearch": "^0.7.43",
    "gray-matter": "^4.0.3",
    "meilisearch": "^0.58.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "latest",
    "@types/flexsearch": "^0.7.42",
    "typescript": "^5.9.0"
  }
}
